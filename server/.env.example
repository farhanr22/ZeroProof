# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database
# Replace with your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/zerotrust?retryWrites=true&w=majority

# Auth
JWT_SECRET=your_super_secret_jwt_key_here

# Internal Service Secrets
OTP_SERVICE_SECRET=your_otp_service_secret_here
SELF_DOMAIN=https://yourapp.com

# Testing
MALICIOUS_MODE=false

# CORS Admin Client app domain
CORS_ORIGIN=http://localhost:5174

